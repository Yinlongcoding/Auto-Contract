{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "外贸单据生成器",
  "version": "1.0.0",
  "identifier": "com.zzyschemical.autocontract",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "外贸单据生成器",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 680,
        "backgroundColor": "#f5f6f8"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [
      "../templates/*"
    ]
  }
}
