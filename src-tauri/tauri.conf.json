{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "外贸单据生成器",
  "version": "1.0.12",
  "identifier": "com.zzyschemical.autocontract",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "外贸单据生成器",
        "width": 452,
        "height": 392,
        "minWidth": 452,
        "minHeight": 392,
        "devtools": false,
        "backgroundColor": "#f5f6f8"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    },
    "resources": [
      "../templates/*"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3MTBCNEY0OUNBNDAzMQpSV1F4UU1wSlR3dHhBN0IwcUZNMit3SERNRHFBU2VydmtBU0N2OTdmanhST3lCdE5DMEhoYmFnMwo=",
      "endpoints": [
        "https://github.com/Yinlongcoding/Auto-Contract/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
